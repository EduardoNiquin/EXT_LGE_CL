{
  "name": "ext-lge-cl",
  "version": "2.3",
  "description": "Browser extension for Chrome and Edge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode chrome",
    "dev:edge": "vite build --watch --mode edge",
    "build:chrome": "vite build --mode chrome",
    "build:edge": "vite build --mode edge",
    "build": "npm run build:chrome && npm run build:edge",
    "package:chrome": "web-ext build --source-dir dist/chrome --artifacts-dir packages",
    "package:edge": "web-ext build --source-dir dist/edge --artifacts-dir packages",
    "build:ext": "vite build --mode edge",
    "pack:ext": "node scripts/pack-extension.mjs --browser=edge",
    "policy:gen": "node scripts/generate-policy.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:ext": "npm run version:bump && npm run build:ext && npm run pack:ext && npm run policy:gen",
    "installer:build": "npm run release:ext && node scripts/build-installer.mjs",
    "install:ext": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall:ext": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1 -Uninstall",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "globals": "^16.0.0",
    "vite": "^8.0.0",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^4.0.0",
    "web-ext": "^10.0.0"
  }
}
